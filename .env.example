# ─── Servidor ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Base de datos ────────────────────────────────────────
MONGO_URI=mongodb+srv://<db_user>:<db_password>@cluster.mongodb.net/prode2026

# ─── Autenticación ────────────────────────────────────────
JWT_SECRET=your_jwt_secret_very_long_and_random
SESSION_SECRET=your_session_secret
COOKIE_SECRET=your_cookie_secret

# ─── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── API externa (api-sports / api-football.com) ──────────
FOOTBALL_API_KEY=your_api_sports_key
WORLD_CUP_LEAGUE_ID=1
API_SEASON=2026

# ─── Webhooks (HMAC-SHA256) ───────────────────────────────
WEBHOOK_SECRET=your_webhook_secret_base64_or_random

# ─── Frontend ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
