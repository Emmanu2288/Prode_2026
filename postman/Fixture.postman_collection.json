{
  "info": {
    "_postman_id": "a12e506c-1c68-4a8e-a6c3-ced5e260f560",
    "name": "Fixture",
    "description": "Obtener partidos del Mundial desde la API de football. NOTA: El plan free tiene límite de 100 requests/día. Si devuelve [] es porque se agotó el cupo del día.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Obtener todos los partidos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Devuelve lista de partidos', () => {",
              "  const data = pm.response.json();",
              "  pm.expect(data).to.be.an('array');",
              "  if (data.length === 0) {",
              "    console.warn('⚠️  Lista vacía — probablemente el rate limit del plan free fue alcanzado.');",
              "    console.warn('   Intentá mañana o usá el plan Pro.');",
              "  } else {",
              "    console.log('✅ Partidos obtenidos:', data.length);",
              "    const p = data[0];",
              "    console.log('Primer partido:', p.fixture?.date, '|', p.teams?.home?.name, 'vs', p.teams?.away?.name);",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/matches",
          "host": ["{{baseUrl}}"],
          "path": ["api", "matches"]
        },
        "description": "Trae los partidos del Mundial 2022 (o 2026 cuando se cambie API_SEASON en .env).\nConsume 1 request de la cuota diaria de api-sports."
      }
    },
    {
      "name": "2. Obtener partidos con filtro de temporada",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Responde correctamente', () => {",
              "  const data = pm.response.json();",
              "  console.log('Partidos obtenidos:', data.length);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/matches?leagueId=1&season=2022",
          "host": ["{{baseUrl}}"],
          "path": ["api", "matches"],
          "query": [
            { "key": "leagueId", "value": "1" },
            { "key": "season", "value": "2022" }
          ]
        },
        "description": "Mismo endpoint pero pasando leagueId y season como query params explícitos."
      }
    }
  ]
}
