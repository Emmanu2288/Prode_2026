      "name": "pruebas",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const secret = pm.environment.get(\"WEBHOOK_SECRET\");\r",
              "const bodyRaw = (pm.request && pm.request.body && pm.request.body.raw)\r",
              "  || (pm.request && pm.request.toJSON && pm.request.toJSON().body && pm.request.toJSON().body.raw)\r",
              "  || null;\r",
              "\r",
              "if (!secret) throw new Error(\"WEBHOOK_SECRET no está definida en el environment\");\r",
              "if (!bodyRaw) throw new Error(\"El body no está en raw → JSON\");\r",
              "\r",
              "const sig = CryptoJS.HmacSHA256(bodyRaw, secret).toString(CryptoJS.enc.Hex);\r",
              "pm.environment.set(\"WEBHOOK_SIG\", sig);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
